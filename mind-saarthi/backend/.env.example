# -----------------------------------------------------------------------------------------
# Example Environment Variables for MindSaarthi Backend
# Copy this file to `.env` and fill in your actual credentials.
# -----------------------------------------------------------------------------------------

# 1. MongoDB Connection String (Update with your own cluster URI)
MONGO_URI=mongodb://localhost:27017/mindsaarthi

# 2. JWT Secret Key (Used for encrypting user tokens, consider changing it for production)
JWT_SECRET_KEY=your-secret-key-here

# 3. Chatbot / Generative AI Keys
# We have added support for Google Gemini to power the chatbot's conversational replies.
# Get your API key from Google AI Studio (https://aistudio.google.com/) and paste it here.
GEMINI_API_KEY=your_gemini_api_key_here
